<Window x:Class="Lab2.App1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab2.App1"
        mc:Ignorable="d"
        Title="Учет студентов" Height="350" Width="700">
    <Grid  Margin="10" >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <DataGrid Name="StudentsGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="StudentsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО Студента" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Физика" Binding="{Binding Physics}" Width="80"/>
                <DataGridTextColumn Header="Математика" Binding="{Binding Math}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel  Grid.Row="1" Margin="0,15,0,0">
            <WrapPanel HorizontalAlignment="Center">
                <Label Content="Уникальный №:"/>
                <TextBox Name="TxtId" Width="50" Margin="5"/>

                <Label Content="ФИО:"/>
                <TextBox Name="TxtName" Width="150" Margin="5"/>

                <Label Content="Телефон:"/>
                <TextBox Name="TxtPhone" Width="110" Margin="5"/>

                <Label Content="Физика:"/>
                <TextBox Name="TxtPhysics" Width="40" Margin="5"/>

                <Label Content="Математика:"/>
                <TextBox Name="TxtMath" Width="40" Margin="5"/>
            </WrapPanel>
            <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Добавить" Width="100" Margin="5" Click="Add_Click"/>
                <Button Content="Сохранить изменения" Width="140" Margin="5" Click="Update_Click"/>
                <Button Content="Удалить" Width="100" Margin="5" Click="Delete_Click"/>
                <Button Content="Очистить поля" Width="100" Margin="5" Click="Clear_Click"/>
            </WrapPanel>
        </StackPanel>




    </Grid>
</Window>
